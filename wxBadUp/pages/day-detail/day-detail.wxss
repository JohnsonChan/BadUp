/* 页面基础布局。 */
page {
  min-height: 100vh;
  background: #f6fbf8;
}

.scrollarea {
  height: calc(100vh - 96rpx);
}

.content {
  padding: 30rpx;
}

/* 页头标题与总计。 */
.day-title {
  margin-top: 18rpx;
  color: #121d1b;
  font-size: 42rpx;
  font-weight: 900;
}

.total-text {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  column-gap: 8rpx;
  margin-top: 8rpx;
  color: #75827f;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.total-name {
  max-width: 100%;
}

.total-count-group {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  white-space: nowrap;
}

.total-count-num {
  margin: 0 8rpx;
  font-weight: 900;
}

/* 24 小时记录列表。 */
.hour-list {
  margin-top: 34rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(0, 0, 0, 0.055);
}

.hour-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  background: rgba(255, 255, 255, 0.78);
}

.hour-row:last-child {
  border-bottom: 0;
}

.hour-text {
  width: 82rpx;
  color: #899491;
  font-size: 23rpx;
}

.hour-line {
  flex: 1;
  height: 2rpx;
  background: rgba(0, 0, 0, 0.10);
}

.hour-count {
  padding: 10rpx 18rpx;
  color: #fff;
  font-size: 23rpx;
  font-weight: 800;
  border-radius: 999rpx;
  white-space: nowrap;
}

.no-count {
  color: #899491;
  font-size: 23rpx;
}
