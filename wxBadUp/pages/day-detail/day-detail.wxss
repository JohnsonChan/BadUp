/* 页面基础布局。 */
page {
  min-height: 100vh;
  background: #f6fbf8;
}

.scrollarea {
  height: calc(100vh - 96rpx);
}

.content {
  padding: 30rpx;
}

/* 页头标题与总计。 */
.day-title {
  margin-top: 18rpx;
  color: #121d1b;
  font-size: 42rpx;
  font-weight: 900;
}

.total-text {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  margin-top: 8rpx;
  color: #75827f;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.total-name {
  max-width: 100%;
}

.total-count-group {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  white-space: nowrap;
  margin-left: 8rpx;
}

.total-count-num {
  margin: 0 8rpx;
  font-weight: 900;
}

/* 24 小时记录列表。 */
.hour-list {
  margin-top: 34rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(0, 0, 0, 0.055);
}

.hour-row {
  display: flex;
  align-items: center;
  height: 92rpx;
  padding: 0 18rpx 0 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  background: rgba(255, 255, 255, 0.78);
}

.clickable-hour {
  cursor: pointer;
}

.hour-row-hover {
  background: rgba(255, 255, 255, 0.95);
}

.hour-row:last-child {
  border-bottom: 0;
}

.hour-text {
  width: 82rpx;
  margin-right: 18rpx;
  color: #899491;
  font-size: 23rpx;
}

.hour-line {
  flex: 1;
  margin-right: 18rpx;
  height: 2rpx;
  background: rgba(0, 0, 0, 0.10);
}

.hour-count {
  flex-shrink: 0;
  min-width: 68rpx;
  padding: 8rpx 10rpx;
  box-sizing: border-box;
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
  border-radius: 999rpx;
  white-space: nowrap;
}

.hour-arrow {
  flex-shrink: 0;
  width: 30rpx;
  margin-left: -6rpx;
  color: #a8b1af;
  font-size: 34rpx;
  line-height: 1;
  text-align: right;
}

.no-count {
  color: #899491;
  font-size: 23rpx;
}

/* 单小时记录明细弹层。 */
.record-sheet-layer {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
}

.record-sheet-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(18, 29, 27, 0.36);
}

.record-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 78vh;
  padding: 18rpx 30rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 34rpx 34rpx 0 0;
  background: #fff;
  box-shadow: 0 -18rpx 46rpx rgba(30, 54, 50, 0.14);
}

.sheet-handle {
  width: 86rpx;
  height: 10rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #dce4e1;
}

.sheet-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.sheet-title {
  color: #121d1b;
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-subtitle {
  margin-top: 6rpx;
  color: #7a8784;
  font-size: 24rpx;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  margin-left: 20rpx;
  color: #7a8784;
  font-size: 42rpx;
  line-height: 50rpx;
  text-align: center;
}

.sheet-loading,
.sheet-empty,
.sheet-error {
  padding: 42rpx 0;
  color: #899491;
  font-size: 26rpx;
  text-align: center;
}

.sheet-error {
  color: #d84f49;
  line-height: 1.45;
}

.record-list {
  max-height: 48vh;
  overflow-y: auto;
}

.record-row {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1ef;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-time {
  color: #121d1b;
  font-size: 30rpx;
  font-weight: 900;
}

.record-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 4rpx;
  color: #7a8784;
  font-size: 24rpx;
  line-height: 1.35;
}

.record-meta-name {
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-separator {
  margin: 0 8rpx;
  color: #a6b0ad;
}

.record-operator {
  color: #f55f52;
}

.record-score.positive {
  color: #43c77a;
}

.record-score.negative {
  color: #f55f52;
}

.record-delete {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(216, 79, 73, 0.10);
  color: #d84f49;
  font-size: 24rpx;
  font-weight: 800;
}
