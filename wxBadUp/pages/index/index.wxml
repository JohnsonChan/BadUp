<!-- 首页：闪屏、习惯按钮、今日统计都集中在这里。 -->
<view class="page">
  <!-- 启动闪屏：逻辑与 iOS 一致，登录失败时继续停留在这里。 -->
  <view wx:if="{{isSplashVisible}}" class="splash">
    <view class="splash-glow splash-glow-a"></view>
    <view class="splash-glow splash-glow-b"></view>

    <view class="splash-brand">
      <view class="splash-title">芽记</view>
      <view class="splash-subtitle">
        <text class="splash-subtitle-line">记录好习惯，然后成长一点</text>
        <text class="splash-subtitle-line">记录坏习惯，然后少做一点</text>
      </view>
    </view>

    <view class="splash-status">
      <block wx:if="{{isLoading}}">
        <view class="loading-dot"></view>
        <text class="status-text">正在登录…</text>
      </block>
      <block wx:elif="{{errorMessage}}">
        <text class="error-text">{{errorMessage}}</text>
        <button class="retry-btn" bindtap="retryLogin">重试</button>
      </block>
      <block wx:else>
        <view class="loading-dot"></view>
      </block>
    </view>
  </view>

  <block wx:else>
    <!-- 顶部导航：只保留标题，避免自定义按钮和微信胶囊挤在同一行。 -->
    <navigation-bar title="{{pageTitle}}" back="{{isSubjectMode}}" color="#142827" background="#F2FCF8"></navigation-bar>

    <!-- 首页头部操作行：放到微信胶囊下方，避免与系统按钮重叠。 -->
    <view class="top-actions">
      <view class="nav-btn" bindtap="goAddBehavior">+</view>
      <view class="nav-more" bindtap="goMore">⋮</view>
    </view>

    <scroll-view class="scrollarea" scroll-y="{{!isSorting && !isLongPressHolding}}">
      <view class="content">
        <!-- 当天概览。 -->
        <view class="hero">
          <view class="hero-title">{{isSubjectMode ? '今日呵护记录' : '今日习惯记录'}}</view>
          <view class="hero-date">{{todayText}}</view>
          <view wx:if="{{isSubjectMode && !canManageSubject}}" class="hero-tip">当前权限仅可查看</view>
        </view>

        <!-- 可点击记录的习惯按钮列表。 -->
        <view class="behavior-list">
          <view
            wx:for="{{behaviors}}"
            wx:key="behaviorId"
            class="behavior-card {{sortingBehaviorId === item.behaviorId ? 'sorting-card' : ''}}"
            style="background: {{item.colorHex}};"
            data-id="{{item.behaviorId}}"
            data-index="{{index}}"
            bindtap="onBehaviorTap"
            bindtouchstart="onBehaviorTouchStart"
            bindtouchmove="onBehaviorTouchMove"
            bindtouchend="onBehaviorTouchEnd"
            bindtouchcancel="onBehaviorTouchCancel"
            bindlongpress="onBehaviorLongPress"
          >
            <view class="behavior-main">
              <view class="behavior-name">{{item.behaviorName}}</view>
              <view wx:if="{{item.behaviorDesc}}" class="behavior-desc">{{item.behaviorCardDesc}}</view>
            </view>
          </view>
        </view>

        <!-- 今日统计列表，点击后进入年/月/日详情。 -->
        <view class="section-title">今天统计</view>
        <view class="count-list">
          <view
            wx:for="{{todayCounts}}"
            wx:key="id"
            class="count-row"
            data-id="{{item.behavior.behaviorId}}"
            bindtap="goYearDetail"
          >
            <view class="color-dot" style="background: {{item.behavior.colorHex}};"></view>
            <view class="count-info">
              <view class="count-name">{{item.behavior.behaviorName}}</view>
              <view wx:if="{{item.behavior.behaviorDesc}}" class="count-desc">{{item.behavior.countRowDesc}}</view>
            </view>
            <view class="count-value" style="color: {{item.behavior.colorHex}};">{{item.count}}<text>次</text></view>
            <view class="chevron">›</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 点击习惯后的确认记录弹窗。 -->
    <view wx:if="{{pendingRecord}}" class="dialog-mask">
      <view class="dialog-card">
        <view class="dialog-bar" style="background: {{pendingRecord.colorHex}};"></view>
        <view class="dialog-title">确认记录</view>
        <view class="dialog-message">
          <text class="dialog-line">确定记录一次“<text class="dialog-highlight" style="color: {{pendingRecord.colorHex}};">{{pendingRecord.behaviorName}}</text>”吗？</text>
        </view>
        <view class="dialog-actions">
          <button class="dialog-btn ghost" bindtap="cancelDialog">取消</button>
          <button class="dialog-btn main" style="background: {{pendingRecord.colorHex}};" bindtap="confirmRecord">确认记录</button>
        </view>
      </view>
    </view>

    <!-- 长按习惯后的编辑 / 删除弹窗。 -->
    <view wx:if="{{pendingAction}}" class="dialog-mask">
      <view class="dialog-card">
        <view class="dialog-bar" style="background: {{pendingAction.colorHex}};"></view>
        <view class="dialog-title">管理习惯项</view>
        <view class="dialog-message">
          <text class="dialog-line">编辑或删除“<text class="dialog-highlight" style="color: {{pendingAction.colorHex}};">{{pendingAction.behaviorName}}</text>”？删除会清除历史。</text>
        </view>
        <view class="dialog-actions">
          <button class="dialog-btn danger" bindtap="askDeleteBehavior">删除</button>
          <button class="dialog-btn main" style="background: {{pendingAction.colorHex}};" bindtap="editBehavior">进入编辑</button>
        </view>
      </view>
    </view>

    <!-- 删除前的二次确认弹窗，避免误删习惯和历史记录。 -->
    <view wx:if="{{pendingDelete}}" class="dialog-mask">
      <view class="dialog-card">
        <view class="dialog-bar danger-bar"></view>
        <view class="dialog-title">确认删除</view>
        <view class="dialog-message">
          <text class="dialog-line">删除“<text class="dialog-highlight danger-text">{{pendingDelete.behaviorName}}</text>”会清除历史记录，且不可恢复。</text>
        </view>
        <view class="dialog-actions">
          <button class="dialog-btn ghost" bindtap="cancelDialog">取消</button>
          <button class="dialog-btn danger-solid" bindtap="deleteBehavior">确认删除</button>
        </view>
      </view>
    </view>

    <!-- 首次登录后的微信资料确认：微信要求头像和昵称由用户主动选择/输入。 -->
    <view wx:if="{{showProfilePrompt}}" class="dialog-mask">
      <view class="dialog-card profile-dialog-card">
        <button class="profile-avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseProfileAvatar">
          <image wx:if="{{profileAvatarPreview}}" class="profile-avatar-image" src="{{profileAvatarPreview}}" mode="aspectFill"></image>
          <view wx:else class="profile-avatar-placeholder">
            <view class="profile-leaf profile-leaf-a"></view>
            <view class="profile-leaf profile-leaf-b"></view>
          </view>
        </button>
        <view class="dialog-title">完善种子信息</view>
        <view class="dialog-message profile-message">
          <text class="dialog-line">选择微信头像和昵称，用于呵护关系里的展示。</text>
        </view>
        <view class="profile-form">
          <view class="profile-field-label">微信昵称</view>
          <input class="profile-nickname-input" type="nickname" value="{{profileNickName}}" placeholder="点击选择或输入昵称" bindinput="onProfileNicknameInput" />
        </view>
        <view class="dialog-actions">
          <button class="dialog-btn ghost" bindtap="closeProfilePrompt">暂不设置</button>
          <button class="dialog-btn main profile-confirm-btn" loading="{{profileSubmitting}}" bindtap="saveWechatProfile">保存资料</button>
        </view>
      </view>
    </view>
  </block>
</view>
