<view class="page">
  <navigation-bar title="更多" color="#182827" background="#F6FBF8"></navigation-bar>

  <view class="content">
    <!-- 当前登录用户的服务端信息。 -->
    <view class="section-title">种子信息</view>
    <view class="card">
      <view class="profile-head">
        <image wx:if="{{hasAvatar}}" class="profile-avatar" src="{{user.avatar}}" mode="aspectFill"></image>
        <view wx:else class="profile-avatar profile-avatar-placeholder">
          <view class="avatar-leaf avatar-leaf-a"></view>
          <view class="avatar-leaf avatar-leaf-b"></view>
        </view>
        <view class="profile-info">
          <view class="profile-name">{{displayName}}</view>
        </view>
      </view>
      <view class="row"><text>种子编号</text><text>{{user.userId || '-'}}</text></view>
      <view class="row clickable-row" bindtap="openCarePage" hover-class="row-hover"><text>呵护关系</text><text>管理关系</text></view>
      <view class="row clickable-row" bindtap="openGrowthIndexPage" hover-class="row-hover"><text>生长指数</text><text class="score-value {{behaviorScoreClass}}">{{behaviorScore}}</text></view>
      <view class="row"><text>播种日期</text><text>{{registerDate}}</text></view>
      <view class="row"><text>发芽土地</text><text>{{platformName}}</text></view>
    </view>

    <!-- 关于我们信息。 -->
    <view class="section-title">关于芽记</view>
    <view class="card">
      <view class="row"><text>当前版本</text><text>{{user.appVersion || '-'}}</text></view>
      <view class="row clickable-row" bindtap="copyContactInfo" hover-class="row-hover"><text>联系我们</text><text>BooTry</text></view>
    </view>
  </view>

  <view class="beian-footer" bindtap="openBeianPage" hover-class="beian-footer-hover">
    <text>ICP备案信息：粤ICP备19008987号-2X</text>
    <text class="beian-arrow">›</text>
  </view>
</view>
