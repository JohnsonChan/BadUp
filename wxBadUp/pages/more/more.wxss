/* 页面和内容容器。 */
page {
  min-height: 100vh;
  background: #f6fbf8;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 30rpx;
}

/* 分组标题与信息卡片。 */
.section-title {
  margin: 18rpx 0;
  color: #1f2d2b;
  font-size: 30rpx;
  font-weight: 900;
}

.card {
  padding: 18rpx 26rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: 0 16rpx 36rpx rgba(30, 54, 50, 0.06);
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 10rpx 0 24rpx;
  margin-bottom: 4rpx;
  border-bottom: 1rpx solid #edf1ef;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #edf8f1;
  overflow: hidden;
}

.profile-avatar-placeholder {
  position: relative;
  background: linear-gradient(145deg, #edf8f1 0%, #d8f0df 54%, #f8fcfa 100%);
  box-shadow: inset 0 0 0 2rpx rgba(27, 75, 62, 0.06);
}

.avatar-leaf {
  position: absolute;
  border-radius: 999rpx 999rpx 999rpx 6rpx;
  background: linear-gradient(145deg, rgba(67, 199, 122, 0.72), rgba(27, 75, 62, 0.14));
  transform: rotate(-36deg);
}

.avatar-leaf-a {
  left: 28rpx;
  top: 38rpx;
  width: 40rpx;
  height: 32rpx;
}

.avatar-leaf-b {
  left: 50rpx;
  top: 46rpx;
  width: 32rpx;
  height: 26rpx;
  transform: rotate(34deg);
  opacity: 0.76;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #1f2d2b;
  font-size: 34rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-subtitle {
  margin-top: 8rpx;
  color: #7a8784;
  font-size: 23rpx;
  font-weight: 700;
}

.row {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1ef;
  color: #1f2d2b;
  font-size: 25rpx;
}

.row:last-child {
  border-bottom: 0;
}

.clickable-row {
  cursor: pointer;
}

.row-hover {
  background: rgba(42, 168, 107, 0.06);
}

/* 左侧字段名固定宽度，右侧内容自适应。 */
.row text:first-child {
  width: 210rpx;
  flex-shrink: 0;
  color: #7a8784;
}

.row text:last-child {
  flex: 1;
  word-break: break-all;
  font-weight: 700;
}

.score-value {
  color: #1f2d2b;
  font-size: 30rpx;
  font-weight: 900;
}

.score-value.positive {
  color: #2aa86b;
}

.score-value.negative {
  color: #d84f49;
}

.muted {
  color: #7a8784;
  font-size: 27rpx;
}

/* 底部备案入口，参考微信“关于”页的弱化信息展示。 */
.beian-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  color: #a8b1af;
  font-size: 24rpx;
}

.beian-footer-hover {
  opacity: 0.65;
}

.beian-arrow {
  font-size: 30rpx;
  line-height: 1;
}
