page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f9f4 0%, #ffffff 100%);
}

.page {
  min-height: 100vh;
}

.growth-content {
  min-height: calc(100vh - 96rpx);
  padding: 42rpx 50rpx 54rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.growth-header {
  z-index: 1;
  text-align: center;
  padding-top: 18rpx;
}

.growth-title {
  margin-left: 10rpx;
  color: #3e2723;
  font-size: 44rpx;
  font-weight: 300;
  letter-spacing: 10rpx;
}

.growth-desc {
  margin-top: 18rpx;
  color: #6d8e6d;
  font-size: 25rpx;
  font-weight: 400;
  line-height: 1.5;
}

.canvas-wrap {
  flex: 1;
  min-height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tree-canvas {
  width: 620rpx;
  height: 620rpx;
}

.growth-footer {
  z-index: 1;
  padding: 34rpx 38rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 44rpx rgba(30, 54, 50, 0.08);
}

.stage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.stage-name {
  color: #2e7d32;
  font-size: 29rpx;
  font-weight: 800;
}

.index-text {
  color: #7a8784;
  font-size: 23rpx;
  white-space: nowrap;
}

.index-text text {
  color: #2e7d32;
  font-weight: 800;
}

.progress-track {
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  background: #e0e7e0;
}

.progress-fill {
  position: relative;
  height: 100%;
  min-width: 0;
  border-radius: 999rpx;
  background: #2e7d32;
  transition: width 0.3s ease;
}

.progress-thumb {
  position: absolute;
  right: -13rpx;
  top: 50%;
  width: 26rpx;
  height: 26rpx;
  box-sizing: border-box;
  border: 4rpx solid #2e7d32;
  border-radius: 999rpx;
  background: #fff;
  transform: translateY(-50%);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.10);
}
